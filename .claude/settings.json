{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)",
      "Bash(git push --force*)",
      "Bash(* --force*)",
      "Edit(CLAUDE.md IMMUTABLE CORE 섹션 수정)"
    ]
  },
  "UserPromptSubmit": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File \"Q:\\Claudework\\bridge base\\tools\\start-backup-daemon.ps1\""
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "\"C:\\Python314\\python.exe\" \"Q:\\Claudework\\bridge base\\tools\\status_writer.py\" PRE"
        }
      ]
    },
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "\"C:\\Python314\\python.exe\" \"Q:\\Claudework\\bridge base\\tools\\bridge_backup.py\" --pre-hook \"$CLAUDE_TOOL_NAME\""
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "\"C:\\Python314\\python.exe\" \"Q:\\Claudework\\bridge base\\tools\\status_writer.py\" POST"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "\"C:\\Python314\\python.exe\" \"Q:\\Claudework\\bridge base\\tools\\status_writer.py\" STOP"
        }
      ]
    },
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "python -X utf8 \"Q:/Claudework/bridge base/tools/auto_finalize.py\" \"$CLAUDE_TASK_TITLE\""
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "echo [TASK] 태스크 완료"
        }
      ]
    }
  ]
}