{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(DROP TABLE*)",
      "Bash(DELETE FROM*)",
      "Bash(git push --force*)",
      "Bash(* --force*)",
      "Edit(CLAUDE.md IMMUTABLE CORE 섹션 수정)"
    ]
  },
  "UserPromptSubmit": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File \"Q:\\Claudework\\bridge base\\tools\\start-backup-daemon.ps1\""
        }
      ]
    },
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"Q:\\Claudework\\bridge base\\tools\\bridge_memory.py\" --event user_prompt"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "cmd /c \"Q:\\Claudework\\bridge base\\tools\\pre_hook.bat\""
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "cmd /c \"Q:\\Claudework\\bridge base\\tools\\post_hook.bat\""
        }
      ]
    },
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"Q:\\Claudework\\bridge base\\tools\\bridge_memory.py\" --event post_tool"
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "cmd /c \"Q:\\Claudework\\bridge base\\tools\\stop_hook.bat\""
        }
      ]
    },
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"Q:\\Claudework\\bridge base\\tools\\bridge_memory.py\" --event stop"
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "matcher": {},
      "hooks": [
        {
          "type": "command",
          "command": "echo [TASK] 태스크 완료"
        }
      ]
    }
  ]
}
