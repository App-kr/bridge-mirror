# ── BRIDGE Platform Environment Variables ──────────────────────
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-key

# ── Security ───────────────────────────────────────────────────
BRIDGE_FIELD_KEY=your-strong-random-key-for-aes-256
JWT_SECRET=your-separate-jwt-secret-key
ADMIN_API_KEY=your-admin-api-key

# ── Environment ────────────────────────────────────────────────
# Set to "production" to disable Swagger docs and enforce admin key
BRIDGE_ENV=development

# ── File Upload Signing ────────────────────────────────────────
# HMAC-SHA256 서명 키 — 업로드 파일 접근 보호 (만료 10분)
UPLOAD_SIGN_KEY=your-upload-sign-key-min-32chars

# ── AWS S3 (파일 업로드) ───────────────────────────────────────
# uploads/ 로컬 저장 대체 — Render 재배포 시 파일 소실 방지
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=bridge-uploads
AWS_REGION=ap-northeast-2

# ── PAYMENT ────────────────────────────────────────────────────
# false → 결제 기능 비활성화 (모든 /api/payments/* 엔드포인트 503 반환)
PAYMENT_ENABLED=false
# PortOne (아임포트) — https://admin.portone.io
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=
# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# 프론트엔드 공개키 (NEXT_PUBLIC_ 접두사 → 브라우저 노출 가능)
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_PAYMENT_ENABLED=false
