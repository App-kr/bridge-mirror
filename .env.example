# ── BRIDGE Platform Environment Variables ──────────────────────
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_KEY=eyJ...your-service-key

# ── Security ───────────────────────────────────────────────────
BRIDGE_FIELD_KEY=your-strong-random-key-for-aes-256
JWT_SECRET=your-separate-jwt-secret-key
ADMIN_API_KEY=your-admin-api-key

# ── Environment ────────────────────────────────────────────────
# Set to "production" to disable Swagger docs and enforce admin key
BRIDGE_ENV=development

# ── File Upload Signing ────────────────────────────────────────
# HMAC-SHA256 서명 키 — 업로드 파일 접근 보호 (만료 10분)
UPLOAD_SIGN_KEY=your-upload-sign-key-min-32chars
