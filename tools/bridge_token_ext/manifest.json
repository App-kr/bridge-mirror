{
  "manifest_version": 3,
  "name": "Bridge ImageFX Token",
  "version": "1.0",
  "description": "Bridge ImageFX auto token refresh",
  "permissions": ["alarms"],
  "host_permissions": [
    "https://labs.google/*",
    "http://localhost:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png"
  }
}
